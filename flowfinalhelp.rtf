    \{\
      "parameters": \{\
        "functionCode": "return items.map(item => \{\\n  const orden           = parseInt(item.json['Orden'] || 999);\\n  const reciente        = item.json.reciente;\\n  const estado          = (item.json['Estatus'] || '').toUpperCase();\\n  const sinAsignar      = item.json.sin_asignar;\\n  const diasIngreso     = item.json.dias_desde_ingreso || 0;\\n  const recienteMensaje = item.json.reciente_mensaje;\\n  const tieneMensaje    = item.json.tiene_mensaje;\\n\\n  // Auto-mensajes del sistema \'97 evaluar una sola vez y reusar\\n  const ultimoMensaje       = String(item.json['Ultimo mensaje'] || '');\\n  const esCambioPrioridad   = /el usuario .+ cambi[o\'f3] la prioridad/i.test(ultimoMensaje);\\n  const esCambioEstatusAuto = /el usuario .+ cambi[o\'f3] (el |la asignaci[o\'f3]n)/i.test(ultimoMensaje);\\n  const esAutoMensaje       = esCambioPrioridad || esCambioEstatusAuto;\\n\\n  // Mensaje autom\'e1tico de cambio de prioridad\\n  if (esCambioPrioridad) \{\\n    item.json.clasificacion = 'SIN ACCION';\\n    item.json.accion = 'CAMBIO DE PRIORIDAD';\\n\\n  // Mensaje autom\'e1tico de cambio de estatus o asignaci\'f3n\\n  \} else if (esCambioEstatusAuto) \{\\n    item.json.clasificacion = 'SIN ACCION';\\n    item.json.accion = 'CAMBIO DE ESTATUS';\\n\\n  // Tickets donde el cliente debe responder\\n  \} else if (estado.includes('ENTREGADO')) \{\\n    item.json.clasificacion = 'CLIENTE PENDIENTE';\\n    item.json.accion = 'NO REQUIERE ATENCION';\\n  \} else if (estado.includes('INFO PENDIENTE CLIENTE')) \{\\n    item.json.clasificacion = 'CLIENTE PENDIENTE';\\n    item.json.accion = 'Esperando respuesta del cliente';\\n\\n  // Tickets sin asignar \'97 posible problema operativo\\n  \} else if (sinAsignar && diasIngreso > 3) \{\\n    item.json.clasificacion = 'VERIFICAR MOTIVO DE NO ASIGNACION';\\n    item.json.accion = 'Sin asignar hace muchos dias - revisar causa';\\n  \} else if (sinAsignar && diasIngreso > 1) \{\\n    item.json.clasificacion = 'SIN ASIGNAR';\\n    item.json.accion = 'Requiere Revision';\\n  \} else if (sinAsignar) \{\\n    item.json.clasificacion = 'SIN ASIGNAR';\\n    item.json.accion = 'Asignar tecnico';\\n\\n  // Tickets activos por urgencia/movimiento\\n  \} else if (orden === 1 && reciente) \{\\n    item.json.clasificacion = 'URGENTE';\\n    item.json.accion = 'Atender inmediatamente';\\n  \} else if (orden <= 2 && reciente) \{\\n    item.json.clasificacion = 'ALTA PRIORIDAD';\\n    item.json.accion = 'Revisar hoy';\\n  \} else if (reciente) \{\\n    item.json.clasificacion = 'RECIENTE';\\n    item.json.accion = 'Validar cambios';\\n  // Mensaje reciente sin atender (tiene prioridad sobre CRITICO SIN MOVIMIENTO)\\n  \} else if (recienteMensaje && tieneMensaje) \{\\n    item.json.clasificacion = 'REQUIERE REVISION';\\n    item.json.accion = 'Mensaje reciente pendiente de revision';\\n\\n  \} else if (orden === 1 && !reciente) \{\\n    item.json.clasificacion = 'CRITICO SIN MOVIMIENTO';\\n    item.json.accion = 'Escalar inmediatamente';\\n\\n  // Otros estados de espera al cliente\\n  \} else if (estado.includes('INFO PENDIENTE')) \{\\n    item.json.clasificacion = 'CLIENTE PENDIENTE';\\n    item.json.accion = 'Esperar respuesta cliente';\\n  \} else \{\\n    item.json.clasificacion = 'SIN ACCION';\\n    item.json.accion = 'No requiere atencion';\\n  \}\\n\\n  // Si el ultimo en modificar fue un empleado FitBank, sobreescribir solo la accion\\n  // (excepto si el \'faltimo mensaje es un auto-mensaje de cambio de prioridad/estatus)\\n  const EMPLEADOS = ['JPHP001','VINC001','MSC001','FSGC001','ORLR001','KIMA001','KDLS001','BMHJ001','DSGS001','JCEO001','CUC001','JFQV001'];\\n  if (!esAutoMensaje && EMPLEADOS.includes(String(item.json['Usuario ultimo mensaje'] || item.json['Usuario ultima modificacion'] || '').trim().toUpperCase()) && !estado.includes('EN PROCESO')) \{\\n    item.json.accion = 'COMENTARIO ENVIADO POR FITBANK';\\n  \}\\n\\n  // Si FitBank coment\'f3 pero el ticket sigue sin asignar, la prioridad es asignar tecnico\\n  if (item.json.accion === 'COMENTARIO ENVIADO POR FITBANK' && item.json.clasificacion === 'SIN ASIGNAR') \{\\n    item.json.accion = 'ASIGNAR TECNICO';\\n  \}\\n\\n  item.json.clasificacion = String(item.json.clasificacion || '').toUpperCase();\\n  item.json.accion        = String(item.json.accion        || '').toUpperCase();\\n\\n  return item;\\n\});"\
      \},\
      "id": "bbb29a35-96f9-4b29-8a05-3fb63c38bbb9",\
