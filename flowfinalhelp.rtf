        "functionCode": "const AUTO_PATTERN = /el usuario .+ (cambi[o\'f3]|ualiz\'f3 .+ asun)/i;\\n\\nfunction stripHtml(str) \{\\n  return String(str || '')\\n    .replace(/<[^>]*>/g, '')\\n    .replace(/&nbsp;/gi, ' ')\\n    .replace(/&amp;/gi, '&')\\n    .replace(/&lt;/gi, '<')\\n    .replace(/&gt;/gi, '>')\\n    .replace(/&quot;/gi, '\\"')\\n    .replace(/\\\\s+/g, ' ')\\n    .trim();\\n\}\\n\\nconst ticketsOriginales = $items('Filtrar Estados');\\n\\nreturn items.map((item, i) => \{\\n  const original = ticketsOriginales[i] ? \{ ...ticketsOriginales[i].json \} : \{\};\\n\\n  let mensajes = [];\\n  try \{\\n    const raw = item.json.messages_raw || '[]';\\n    mensajes = JSON.parse(raw);\\n    if (!Array.isArray(mensajes)) mensajes = [];\\n  \} catch(e) \{\}\\n\\n  let encontrado = false;\\n  for (let j = mensajes.length - 1; j >= 0; j--) \{\\n    const m = mensajes[j];\\n    if (\\n      m.system_message === false &&\\n      m.detail && String(m.detail).trim() &&\\n      !AUTO_PATTERN.test(m.detail)\\n    ) \{\\n      original['Ultimo mensaje']         = stripHtml(m.detail);\\n      original['Fecha ultimo mensaje']   = m.entry_date;\\n      original['Usuario ultimo mensaje'] = m.entry_user_id;\\n      encontrado = true;\\n      break;\\n    \}\\n  \}\\n\\n  if (!encontrado) \{\\n    original['Usuario ultimo mensaje'] = original['Usuario ultima modificacion'] || '';\\n  \}\\n\\n  return \{ json: original \};\\n\});\\n"\
