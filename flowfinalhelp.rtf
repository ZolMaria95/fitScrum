      "parameters": \{\
        "functionCode": "const TIPO_NOMBRE = \{ '001': 'INCIDENCIA', '002': 'REQUERIMIENTO', '003': 'CONSULTA' \};\\n\\nreturn items.map(item => \{\\n  const t = item.json;\\n  return \{\\n    json: \{\\n      'Numero ticket':           t.ticket_id,\\n      'Tipo':                    t.ticket_type_id || '',\\n      'Tipo nombre':             TIPO_NOMBRE[t.ticket_type_id] || t.ticket_type_id || '',\\n      'Cliente':                 t.cliente || '',\\n      'Usuario ingreso':         t.entry_user_id || '',\\n      'Nombre usuario ingreso':  t.entry_person || '',\\n      'Usuario asignado':        t.assigned_user_id || '',\\n      'Nombre usuario asignado': t.assigned_person || '',\\n      'Orden':                   t.priority || 999,\\n      'Estatus':                 t.estado || '',\\n      'Asunto':                  t.subject || '',\\n      'Modulo':                  t.modulo || '',\\n      'Fecha asignacion':        t.assigned_date || '',\\n      'Fecha ingreso':           t.entry_date || '',\\n      'Fecha modificacion':      t.modified_date || '',\\n      'Usuario ultima modificacion': t.assigned_user_id || '',\\n      'Ultimo mensaje':          '',\\n      'Fecha ultimo mensaje':    '',\\n      'Usuario ultimo mensaje':  ''\\n    \}\\n  \};\\n\});"\
