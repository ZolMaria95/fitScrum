    \{\
      "parameters": \{\
        "functionCode": "const XLSX_PATH = '/usr/local/lib/node_modules/n8n/node_modules/.pnpm/xlsx@https+++cdn.sheetjs.com+xlsx-0.20.2+xlsx-0.20.2.tgz/node_modules/xlsx/xlsx.js';\\nconst XLSX = require(XLSX_PATH);\\n\\nconst CLASIF_COLOR = \{\\n  'URGENTE':                           'FFFF4444',\\n  'CRITICO SIN MOVIMIENTO':            'FFC00000',\\n  'ALTA PRIORIDAD':                    'FFFF8C00',\\n  'RECIENTE':                          'FF2196F3',\\n  'REQUIERE REVISION':                 'FFFF5722',\\n  'CLIENTE PENDIENTE':                 'FF9C27B0',\\n  'VERIFICAR MOTIVO DE NO ASIGNACION': 'FFFF6D00',\\n  'SIN ASIGNAR':                       'FFFFC107',\\n  'SIN ACCION':                        'FF9E9E9E',\\n  'COMENTARIO ENVIADO POR FITBANK':    'FF00897B'\\n\};\\n\\nconst COL_ORDER = [\\n  'Numero ticket','Cliente','Asunto','Fecha ultimo mensaje','Ultimo mensaje',\\n  'Tipo nombre','Tipo','Usuario ingreso','Nombre usuario ingreso',\\n  'Usuario asignado','Nombre usuario asignado','Orden','Estatus',\\n  'Modulo','Fecha asignacion','Fecha ingreso',\\n  'dias_sin_movimiento','dias_desde_ingreso',\\n  'Fecha modificacion','Usuario ultima modificacion','clasificacion','Cliente','accion'\\n];\\n\\nfunction mkStyle(bgArgb, fgArgb, bold, halign) \{\\n  return \{\\n    fill: \{ patternType: 'solid', fgColor: \{ argb: bgArgb \} \},\\n    font: \{ name: 'Arial', sz: bold ? 10 : 9, bold: !!bold, color: \{ argb: fgArgb || 'FF000000' \} \},\\n    alignment: \{ horizontal: halign || 'left', vertical: 'center', wrapText: true \},\\n    border: \{\\n      top:    \{ style: 'thin', color: \{ argb: 'FFBDD7EE' \} \},\\n      bottom: \{ style: 'thin', color: \{ argb: 'FFBDD7EE' \} \},\\n      left:   \{ style: 'thin', color: \{ argb: 'FFBDD7EE' \} \},\\n      right:  \{ style: 'thin', color: \{ argb: 'FFBDD7EE' \} \}\\n    \}\\n  \};\\n\}\\n\\nconst PRIORITY_ACTIONS = new Set([\\n  'ASIGNAR TECNICO',\\n  'REQUIERE REVISION',\\n  'ESCALAR INMEDIATAMENTE',\\n  'ATENDER INMEDIATAMENTE',\\n  'REVISAR HOY'\\n]);\\n\\nfunction buildSheet(rows) \{\\n  const ws = \{\};\\n  const iClasif    = COL_ORDER.indexOf('clasificacion');\\n  const iDias      = COL_ORDER.indexOf('dias_sin_movimiento');\\n  const iDiasIng   = COL_ORDER.indexOf('dias_desde_ingreso');\\n  const iFechaMsg  = COL_ORDER.indexOf('Fecha ultimo mensaje');\\n  const iUltimoMsg = COL_ORDER.indexOf('Ultimo mensaje');\\n\\n  COL_ORDER.forEach((h, c) => \{\\n    const addr = XLSX.utils.encode_cell(\{ r: 0, c \});\\n    ws[addr] = \{ v: h, t: 's' \};\\n    ws[addr].s = mkStyle('FF1F3864', 'FFFFFFFF', true, 'center');\\n  \});\\n\\n  rows.forEach((row, ri) => \{\\n    const bg     = ri % 2 === 0 ? 'FFEBF3FB' : 'FFFFFFFF';\\n    const clasif = String(row['clasificacion'] || '').trim().toUpperCase();\\n    const dias   = parseInt(row['dias_sin_movimiento']) || 0;\\n\\n    COL_ORDER.forEach((col, c) => \{\\n      const addr = XLSX.utils.encode_cell(\{ r: ri + 1, c \});\\n      const val  = row[col] !== undefined && row[col] !== null ? row[col] : '';\\n      const t    = typeof val === 'number' ? 'n' : 's';\\n      ws[addr] = \{ v: val, t \};\\n      ws[addr].s = mkStyle(bg, 'FF000000', false, 'left');\\n\\n      if (c === iClasif && CLASIF_COLOR[clasif]) \{\\n        ws[addr].s.font = \{ name: 'Arial', sz: 9, bold: true, color: \{ argb: CLASIF_COLOR[clasif] \} \};\\n      \}\\n      if (c === iDias) \{\\n        const dc = dias > 7 ? 'FFC00000' : dias > 3 ? 'FFFF8C00' : 'FF2E7D32';\\n        ws[addr].s.font = \{ name: 'Arial', sz: 9, bold: true, color: \{ argb: dc \} \};\\n        ws[addr].s.alignment = \{ horizontal: 'center', vertical: 'center' \};\\n      \}\\n      if (c === iDiasIng) \{\\n        const diasIng = parseInt(row['dias_desde_ingreso']) || 0;\\n        const di = diasIng > 7 ? 'FFC00000' : diasIng > 3 ? 'FFFF8C00' : 'FF2E7D32';\\n        ws[addr].s.font = \{ name: 'Arial', sz: 9, bold: true, color: \{ argb: di \} \};\\n        ws[addr].s.alignment = \{ horizontal: 'center', vertical: 'center' \};\\n      \}\\n      if (c === iFechaMsg && row['reciente_mensaje']) \{\\n        ws[addr].s.fill = \{ patternType: 'solid', fgColor: \{ argb: 'FFFFE0B2' \} \};\\n        ws[addr].s.font = \{ name: 'Arial', sz: 9, bold: true, color: \{ argb: 'FFE65100' \} \};\\n      \}\\n      if (c === iUltimoMsg && row['tiene_mensaje']) \{\\n        ws[addr].s.font = \{ name: 'Arial', sz: 9, bold: true, color: \{ argb: 'FF1A237E' \} \};\\n      \}\\n    \});\\n  \});\\n\\n  ws['!ref']       = XLSX.utils.encode_range(\{ s: \{ r: 0, c: 0 \}, e: \{ r: rows.length, c: COL_ORDER.length - 1 \} \});\\n  ws['!cols']      = COL_ORDER.map(h => \{\\n    let max = h.length;\\n    rows.forEach(row => \{ const l = String(row[h] || '').length; if (l > max) max = l; \});\\n    return \{ wch: Math.min(max + 4, 50) \};\\n  \});\\n  ws['!freeze']    = \{ xSplit: 0, ySplit: 1 \};\\n  ws['!autofilter'] = \{ ref: ws['!ref'] \};\\n  return ws;\\n\}\\n\\n// \uc0\u9472 \u9472  Construir hojas \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \\nconst dataRows = items.map(i => i.json);\\nconst wb = XLSX.utils.book_new();\\n\\nconst prioRows = dataRows.filter(row => PRIORITY_ACTIONS.has(String(row['accion'] || '').trim().toUpperCase()));\\nXLSX.utils.book_append_sheet(wb, buildSheet(prioRows), 'Prioritarios');\\nXLSX.utils.book_append_sheet(wb, buildSheet(dataRows), 'Tickets');\\n\\n// \u9472 \u9472  Estad\'edsticas \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \\nconst stats = \{ total: 0, porClasif: \{\}, porCliente: \{\}, porEstatus: \{\} \};\\ndataRows.forEach(row => \{\\n  const cli = String(row['Cliente']       || '').trim();\\n  const est = String(row['Estatus']       || '').trim();\\n  const cla = String(row['clasificacion'] || '').trim();\\n  if (!cli) return;\\n  stats.total++;\\n  stats.porClasif[cla]  = (stats.porClasif[cla]  || 0) + 1;\\n  stats.porCliente[cli] = (stats.porCliente[cli] || 0) + 1;\\n  stats.porEstatus[est] = (stats.porEstatus[est] || 0) + 1;\\n\});\\n\\nconst wsS = \{\};\\nlet sr = 0;\\n\\nfunction sc(r, c, val, bg, fg, bold, align) \{\\n  const addr = XLSX.utils.encode_cell(\{ r, c \});\\n  wsS[addr] = \{ v: val, t: typeof val === 'number' ? 'n' : 's' \};\\n  wsS[addr].s = mkStyle(bg || 'FFFFFFFF', fg || 'FF000000', bold, align || 'left');\\n\}\\n\\nsc(sr, 1, 'RESUMEN EJECUTIVO - Total tickets activos: ' + stats.total, 'FF1F3864', 'FFFFFFFF', true, 'center');\\nsr += 2;\\n\\nsc(sr, 1, 'POR CLASIFICACION', 'FF2C5F8A', 'FFFFFFFF', true, 'center'); sr++;\\nsc(sr, 1, 'Clasificacion', 'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsc(sr, 2, 'Tickets',       'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsc(sr, 3, '% del Total',   'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsr++;\\n['URGENTE','CRITICO SIN MOVIMIENTO','ALTA PRIORIDAD','RECIENTE','REQUIERE REVISION','CLIENTE PENDIENTE','VERIFICAR MOTIVO DE NO ASIGNACION','SIN ASIGNAR','COMENTARIO ENVIADO POR FITBANK','SIN ACCION'].forEach((cla, i) => \{\\n  const cnt = stats.porClasif[cla] || 0;\\n  const pct = stats.total ? (cnt / stats.total * 100).toFixed(1) + '%' : '0%';\\n  const bg  = i % 2 === 0 ? 'FFEBF3FB' : 'FFFFFFFF';\\n  sc(sr, 1, cla, bg, CLASIF_COLOR[cla] || 'FF000000', true,  'left');\\n  sc(sr, 2, cnt, bg, 'FF000000',                      false, 'center');\\n  sc(sr, 3, pct, bg, 'FF000000',                      false, 'center');\\n  sr++;\\n\});\\nsc(sr, 1, 'TOTAL',     'FF1F3864', 'FFFFFFFF', true, 'center');\\nsc(sr, 2, stats.total, 'FF1F3864', 'FFFFFFFF', true, 'center');\\nsc(sr, 3, '100%',      'FF1F3864', 'FFFFFFFF', true, 'center');\\nsr += 2;\\n\\nsc(sr, 1, 'POR CLIENTE', 'FF2C5F8A', 'FFFFFFFF', true, 'center'); sr++;\\nsc(sr, 1, 'Cliente',     'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsc(sr, 2, 'Tickets',     'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsc(sr, 3, '% del Total', 'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsr++;\\nObject.entries(stats.porCliente).sort((a,b) => b[1]-a[1]).forEach(([cli, cnt], i) => \{\\n  const pct = stats.total ? (cnt / stats.total * 100).toFixed(1) + '%' : '0%';\\n  const bg  = i % 2 === 0 ? 'FFEBF3FB' : 'FFFFFFFF';\\n  sc(sr, 1, cli, bg, 'FF000000', false, 'left');\\n  sc(sr, 2, cnt, bg, 'FF000000', false, 'center');\\n  sc(sr, 3, pct, bg, 'FF000000', false, 'center');\\n  sr++;\\n\});\\nsr++;\\n\\nsc(sr, 1, 'POR ESTATUS', 'FF2C5F8A', 'FFFFFFFF', true, 'center'); sr++;\\nsc(sr, 1, 'Estatus',     'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsc(sr, 2, 'Tickets',     'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsc(sr, 3, '% del Total', 'FF2C5F8A', 'FFFFFFFF', true, 'center');\\nsr++;\\nObject.entries(stats.porEstatus).sort((a,b) => b[1]-a[1]).forEach(([est, cnt], i) => \{\\n  const pct = stats.total ? (cnt / stats.total * 100).toFixed(1) + '%' : '0%';\\n  const bg  = i % 2 === 0 ? 'FFEBF3FB' : 'FFFFFFFF';\\n  sc(sr, 1, est, bg, 'FF000000', false, 'left');\\n  sc(sr, 2, cnt, bg, 'FF000000', false, 'center');\\n  sc(sr, 3, pct, bg, 'FF000000', false, 'center');\\n  sr++;\\n\});\\n\\nwsS['!ref']  = XLSX.utils.encode_range(\{ s: \{ r: 0, c: 0 \}, e: \{ r: sr, c: 4 \} \});\\nwsS['!cols'] = [\{ wch: 3 \}, \{ wch: 34 \}, \{ wch: 12 \}, \{ wch: 14 \}];\\nXLSX.utils.book_append_sheet(wb, wsS, 'Estadisticas');\\n\\n// \u9472 \u9472  Escribir y devolver \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \u9472 \\nconst outBuffer = XLSX.write(wb, \{ type: 'buffer', bookType: 'xlsx', cellStyles: true \});\\nconst base64 = outBuffer.toString('base64');\\n\\nreturn [\{\\n  json: \{ success: true, totalTickets: stats.total \},\\n  binary: \{\\n    data: \{\\n      data: base64,\\n      mimeType: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',\\n      fileName: 'reporte_helpdesk.xlsx',\\n      fileExtension: 'xlsx'\\n    \}\\n  \}\\n\}];"\
