    \{\
      "parameters": \{\
        "functionCode": "const ahora = new Date(new Date().toLocaleString('en-US', \{ timeZone: 'America/Guayaquil' \}));\\nreturn items.map(item => \{\\n  const fechaMod     = new Date(item.json['Fecha modificacion']);\\n  const fechaIng     = new Date(item.json['Fecha ingreso']);\\n  const fechaMensaje = new Date(item.json['Fecha ultimo mensaje']);\\n  const diffMod     = (ahora - fechaMod)     / (1000 * 60 * 60 * 24);\\n  const diffIng     = (ahora - fechaIng)     / (1000 * 60 * 60 * 24);\\n  const diffMensaje = (ahora - fechaMensaje) / (1000 * 60 * 60 * 24);\\n  item.json.reciente            = !isNaN(fechaMod.getTime()) && diffMod <= 2;\\n  item.json.dias_sin_movimiento = isNaN(diffMod) ? 0 : Math.floor(diffMod);\\n  item.json.dias_desde_ingreso  = isNaN(diffIng) ? Math.floor(diffMod) : Math.floor(diffIng);\\n  item.json.sin_asignar         = !String(item.json['Usuario asignado'] || '').trim() || String(item.json['Usuario asignado'] || '').trim().toUpperCase() === 'SIN ASIGNAR';\\n  item.json.reciente_mensaje    = !isNaN(fechaMensaje.getTime()) && diffMensaje <= 2;\\n  item.json.tiene_mensaje       = !!String(item.json['Ultimo mensaje'] || '').trim();\\n  return item;\\n\});"\
