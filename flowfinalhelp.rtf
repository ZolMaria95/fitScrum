        "functionCode": "const clientes = [\\n  'COOPERATIVA DE AHORRO Y CREDITO ERCO',\\n  'COAC CAPCPE GUALAQUIZA',\\n  'COAC LA DOLOROSA DURAN',\\n  'PADRE JULIAN LORENTE',\\n  'COAC CACEL',\\n  'COAC 4 RIOS',\\n  'LITARGMODE CIA LTDA',\\n  'COAC COPAC AUSTRO LTDA',\\n  'BANCO DEL AUSTRO',\\n  'VAZCREDIT',\\n  'COAC SE\'d1OR DE GIRON'\\n];\\nreturn items.filter(i => \{\\n  const cliente = String(i.json['Cliente'] || '').trim().toUpperCase();\\n  return clientes.includes(cliente);\\n\});"\
