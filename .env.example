# ── MongoDB ───────────────────────────────────────────────
# Obtén este URI desde MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=fitdaily

# ── App ───────────────────────────────────────────────────
# "development" habilita /docs y stack traces. Usar "production" en Render.
ENVIRONMENT=development

# Lista de orígenes permitidos, separados por coma.
# En local: incluye el puerto de uvicorn. En producción: solo tu dominio Render.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Auth JWT ──────────────────────────────────────────────
# Genera un valor seguro: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace_this_with_a_secure_random_value_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
